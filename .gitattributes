# The embedded deploy asset tarball is generated by `mage genAssets` (regenerated on every build).
# Mark it binary + generated so GitHub collapses it in diffs and excludes it from language stats
# and code review — it is a build artifact, not hand-written source.
assets/deploy.tar.gz binary linguist-generated=true

# Vendored Go dependencies of the reference deploy-target app are not our source.
deploy/tasks-app/backend/vendor/** linguist-vendored=true

# Documentation diagrams: the *.svg files are the hand-authored source; the *.png next to them
# are generated by scripts/render-diagrams.sh and embedded in the docs. Mark PNGs binary +
# generated so GitHub collapses them in diffs and excludes them from language stats.
docs/diagrams/*.png binary linguist-generated=true
